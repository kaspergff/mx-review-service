MX_PAT=your-mendix-personal-access-token
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
WEBHOOK_SECRET=your-hmac-secret-32-bytes-min
ALLOWED_APP_IDS=8c909cbd-88ab-4a42-bcd2-3b48fc314ff4,another-app-id

# LLM — kies één provider en vul de bijbehorende API key in
LLM_MODEL=claude-sonnet-4-20250514   # Anthropic
# LLM_MODEL=gpt-4o                   # OpenAI
# LLM_MODEL=gemini/gemini-1.5-pro    # Google Gemini
# LLM_MODEL=azure/gpt-4o             # Azure OpenAI

# Zet de API key van je gekozen provider:
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# AZURE_API_KEY=...
# AZURE_API_BASE=https://jouw-deployment.openai.azure.com/
# AZURE_API_VERSION=2024-05-01-preview
